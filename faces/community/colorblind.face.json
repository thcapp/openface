    },
    "mouth": {
      "width": 0.16,
      "verticalPosition": 0.13,
      "style": "curve",
      "speakingBase": 0.1,
      "constraints": {
        "openMin": 0,
        "openMax": 0.8,
        "widthMin": -0.3,
        "widthMax": 0.3

      "spacing": 0.16,
      "verticalPosition": -0.05,
      "stateScales": {
        "idle": [
          1,
          1
        ],
        "thinking": [
          0.85,
          0.85
        ],
        "working": [
          0.92,
          0.92
        ],
        "speaking": [
          1,
          1
        ],
        "listening": [
          1.25,
          1.25
        ],
        "reacting": [
          1.4,
          1.4
        ],
        "puzzled": [

{
  "$schema": "https://openface.live/protocol/v1/face.schema.json",
  "$type": "face",
  "$version": "1.0.0",
  "meta": {
    "name": "Default",
    "author": "Agent Face",
    "license": "MIT",
    "description": "The original Agent Face — Nick Jr inspired, geometric, bold"
  },
  "geometry": {
    "shape": "fullscreen",
    "head": {
      "shape": "fullscreen"
    },
    "eyes": {
      "style": "oval",
      "baseWidth": 0.042,
      "baseHeight": 0.124,
      "spacing": 0.16,
      "verticalPosition": -0.05,
      "stateScales": {
        "idle": [
          1,
          1
        ],
        "thinking": [
          0.9,
          0.9
        ],
        "working": [
          0.95,
          0.95
        ],
        "speaking": [
          1,
          1
        ],
        "listening": [
          1.2,
          1.2
        ],
        "reacting": [
          1.35,
          1.35
        ],
        "puzzled": [
          0.85,
          1.2
        ],
        "alert": [
          1.5,
          1.5
        ],
        "sleeping": [
          1,
          1
        ],
        "waiting": [
          1,
          1
        ],
        "loading": [
          0.8,
          0.8
        ]
      },
      "pupil": {
        "enabled": true,
        "size": 0.2,
        "shiftX": 0.45,
        "shiftY": 0.42,
        "lookFollow": 0.82
      },
      "eyelid": {
        "renderer": "cover",
        "strength": 0.25
      },
      "constraints": {
        "scaleMin": 0.65,
        "scaleMax": 1.45
      },
      "specular": {
        "enabled": true,
        "size": 0.22,
        "shiftX": 0.4,
        "shiftY": 0.35,
        "lookFollow": 0.16,
        "alpha": 1
      }
    },
    "mouth": {
      "width": 0.16,
      "verticalPosition": 0.13,
      "style": "curve",
      "speakingBase": 0.1,
      "constraints": {
        "openMin": 0,
        "openMax": 0.9,
        "widthMin": -0.35,
        "widthMax": 0.35
      }
    },
    "brows": {
      "enabled": true,
      "baseThickness": 0.18,
      "range": 0.05,
      "curveRange": 0.025,
      "verticalOffset": 1.2,
      "renderer": "line",
      "constraints": {
        "min": -0.8,
        "max": 0.9
      }
    },
    "blush": {
      "enabled": true,
      "maxAlpha": 0.2,
      "size": 0.6
    }
  },
  "palette": {
    "feature": "#111111",
    "blush": "#FF8A80",
    "states": {
      "idle": "#4FC3F7",
      "thinking": "#CE93D8",
      "speaking": "#4FC3F7",
      "listening": "#81C784",
      "reacting": "#FFB74D",
      "puzzled": "#FF8A65",
      "alert": "#E57373",
      "working": "#90CAF9",
      "sleeping": "#7986CB",
      "waiting": "#B0BEC5",
      "loading": "#78909C"
    },
    "emotions": {
      "neutral": null,
      "happy": "#FFD54F",
      "sad": "#7986CB",
      "confused": "#FF8A65",
      "excited": "#FF7043",
      "concerned": "#B0BEC5",
      "surprised": "#FFF176",
      "playful": "#F48FB1",
      "frustrated": "#EF5350",
      "skeptical": "#BCAAA4",
      "determined": "#66BB6A",
      "embarrassed": "#F48FB1",
      "proud": "#FFB300"
    },
    "emotionColorBlend": 0.5,
    "specular": "#FFFFFF"
  },
  "animation": {
    "breathAmount": 0.02,
    "breathY": 0.012,
    "headSway": 0.01,
    "blinkInterval": [
      2.5,
      4.5
    ],
    "doubleBlink": 0.15,
    "colorSpeed": {
      "default": 0.04,
      "alert": 0.15,
      "sleeping": 0.02
    },
    "lerp": {
      "amplitude": 0.35,
      "lookAt": 0.06,
      "mouth": 0.3,
      "happiness": 0.12,
      "confusion": 0.2,
      "brows": 0.18,
      "eyeScale": 0.12,
      "tilt": 0.08,
      "blush": 0.1,
      "wink": 0.35,
      "lid": 0.4
    },
    "microExpressions": {
      "enabled": true,
      "eyeDart": {
        "interval": [
          8,
          20
        ],
        "rangeX": 0.4,
        "rangeY": 0.2,
        "duration": 0.3
      },
      "mouthTwitch": {
        "interval": [
          8,
          15
        ],
        "range": 0.1
      }
    }
  },
  "personality": {
    "energy": 0.5,
    "expressiveness": 0.7,
    "warmth": 0.5,
    "stability": 0.7,
    "playfulness": 0.4

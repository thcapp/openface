{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ESNext", "DOM"]
  },
  "references": [
    { "path": "packages/renderer" },
    { "path": "packages/element" },
    { "path": "packages/server" },
    { "path": "packages/client" },
    { "path": "packages/mcp" },
    { "path": "packages/server-edge" }
  ]
}
